   "cell_type": "code",
   "source": [
    "def rhombus(length, angle):\n",
    "    for i in range(2):\n",
    "        forward(length)\n",
    "        left(angle)\n",
    "        forward(length)\n",
    "        left(180 - angle)"
   ],
