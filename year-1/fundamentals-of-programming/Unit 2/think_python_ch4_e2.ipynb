   "cell_type": "code",
   "source": [
    "def rectangle(wide, tall): # draws a rectangle with given side lengths\n",
    "    for i in range(2):\n",
    "        forward(wide)\n",
    "        left(90)\n",
    "        forward(tall)\n",
    "        left(90)"
   ],
